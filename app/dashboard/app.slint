import { UAppTheme } from "@sleek-ui/app-theme.slint";
import { HomePage } from "pages/home/page.slint";
import {
    HomeDeviceStatusColor,
    HomeDeviceStatusItem,
    HomePageDefaults,
    HomeLogItem,
    HomeLogLevel,
    HomeRealtimeFieldItem,
} from "pages/home/models.slint";
import "../static/DingTalk-JinBuTi.ttf";

export component App inherits Window {
    in-out property <string> weight_value: HomePageDefaults.weight_value;
    in-out property <string> weight_unit_label: HomePageDefaults.weight_unit_label;
    in-out property <string> weight_unit: HomePageDefaults.weight_unit;
    in-out property <[HomeDeviceStatusItem]> device_statuses: HomePageDefaults.device_statuses;
    in-out property <[HomeLogItem]> log_items: HomePageDefaults.log_items;
    in-out property <[HomeRealtimeFieldItem]> realtime_fields: HomePageDefaults.realtime_fields;
    in-out property <string> gross_weight: HomePageDefaults.gross_weight;
    in-out property <string> tare_weight: HomePageDefaults.tare_weight;
    in-out property <string> net_weight: HomePageDefaults.net_weight;
    in-out property <[string]> process_step_labels: HomePageDefaults.process_step_labels;
    in-out property <int> current_step_index: HomePageDefaults.current_step_index;

    callback request_refresh_home_data();
    callback request_select_process_step(int);
    callback request_switch_monitor_panel(int);
    callback request_close_app();

    preferred-width: 1180px;
    preferred-height: 760px;
    full-screen: true;
    no-frame: true;
    title: "称重系统";
    icon: @image-url("../static/app-icon.svg");
    background: UAppTheme.bg-layout;
    default-font-family: "DingTalk JinBuTi";

    HomePage {
        width: parent.width;
        height: parent.height;
        weight_value <=> root.weight_value;
        weight_unit_label <=> root.weight_unit_label;
        weight_unit <=> root.weight_unit;
        device_statuses <=> root.device_statuses;
        log_items <=> root.log_items;
        realtime_fields <=> root.realtime_fields;
        gross_weight <=> root.gross_weight;
        tare_weight <=> root.tare_weight;
        net_weight <=> root.net_weight;
        process_step_labels <=> root.process_step_labels;
        current_step_index <=> root.current_step_index;

        request_refresh_home_data => {
            root.request_refresh_home_data();
        }

        request_select_process_step(step_index) => {
            root.request_select_process_step(step_index);
        }

        request_switch_monitor_panel(panel_index) => {
            root.request_switch_monitor_panel(panel_index);
        }
    }

    Rectangle {
        width: 15px;
        height: 15px;
        x: root.width - self.width - 6px;
        y: 6px;
        border-radius: 13px;
        background: #FF5F57;
        border-width: 1px;
        border-color: #E34A43;

        close_touch := TouchArea {
            mouse-cursor: pointer;
            clicked => {
                root.request_close_app();
            }
        }

        Text {
            width: parent.width;
            height: parent.height;
            text: "×";
            horizontal-alignment: center;
            vertical-alignment: center;
            font-size: 18px;
            font-weight: 700;
            color: close_touch.has-hover ? #151515 : transparent;
        }
    }
}
