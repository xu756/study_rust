import {
    LogCard,
    PanelPlaceholderCard,
    ProcessStepCard,
    RealtimeInfoCard,
    WeightStatusCard,
} from "components/page.slint";
import {
    HomeDeviceStatusItem,
    HomeLogItem,
    HomePageDefaults,
    HomeRealtimeFieldItem,
} from "models.slint";

export component HomePage inherits Rectangle {
    in property <string> weight_value: HomePageDefaults.weight_value;
    in property <string> weight_unit_label: HomePageDefaults.weight_unit_label;
    in property <string> weight_unit: HomePageDefaults.weight_unit;
    in property <[HomeDeviceStatusItem]> device_statuses: HomePageDefaults.device_statuses;
    in property <[HomeLogItem]> log_items: HomePageDefaults.log_items;
    in property <[HomeRealtimeFieldItem]> realtime_fields: HomePageDefaults.realtime_fields;
    in property <[string]> recent_weight_records: HomePageDefaults.recent_weight_records;
    in property <string> gross_weight: HomePageDefaults.gross_weight;
    in property <string> tare_weight: HomePageDefaults.tare_weight;
    in property <string> net_weight: HomePageDefaults.net_weight;
    in property <[string]> process_step_labels: HomePageDefaults.process_step_labels;
    in property <int> current_step_index: HomePageDefaults.current_step_index;

    callback request_refresh_home_data();
    callback request_select_process_step(int);
    callback request_switch_monitor_panel(int);
    // 页面四周留白。
    private property <length> page_padding: 20px;
    // 卡片之间统一间距。
    private property <length> card_gap: 16px;
    // 顶部三张卡片统一高度。
    private property <length> top_card_height: 156px;
    // 内容区可用宽度。
    private property <length> content_width: root.width - root.page_padding * 2;
    // 单张顶部卡片宽度，保证第一行严格等宽。
    private property <length> top_card_width: (root.content_width - root.card_gap * 2) / 3;
    // 底部左侧卡片宽度，占前两列并加上中间间距。
    private property <length> bottom_left_width: root.top_card_width * 2 + root.card_gap;
    // 底部内容起始位置。
    private property <length> bottom_row_y: root.page_padding + root.top_card_height + root.card_gap;
    // 底部卡片高度，占满剩余空间。
    private property <length> bottom_card_height: root.height - root.bottom_row_y - root.page_padding;

    clip: true;
    background: transparent;

    WeightStatusCard {
        x: root.page_padding;
        y: root.page_padding;
        width: root.top_card_width;
        height: root.top_card_height;
        weight_value: root.weight_value;
        weight_unit_label: root.weight_unit_label;
        weight_unit: root.weight_unit;
        device_statuses: root.device_statuses;
    }

    LogCard {
        x: root.page_padding + root.top_card_width + root.card_gap;
        y: root.page_padding;
        width: root.top_card_width;
        height: root.top_card_height;
        log_items: root.log_items;
    }

    ProcessStepCard {
        x: root.page_padding + (root.top_card_width + root.card_gap) * 2;
        y: root.page_padding;
        width: root.top_card_width;
        height: root.top_card_height;
        step_labels: root.process_step_labels;
        current_step_index: root.current_step_index;
    }

    RealtimeInfoCard {
        x: root.page_padding;
        y: root.bottom_row_y;
        width: root.bottom_left_width;
        height: root.bottom_card_height;
        realtime_fields: root.realtime_fields;
        recent_weight_records: root.recent_weight_records;
        gross_weight: root.gross_weight;
        tare_weight: root.tare_weight;
        net_weight: root.net_weight;
    }

    PanelPlaceholderCard {
        x: root.page_padding + (root.top_card_width + root.card_gap) * 2;
        y: root.bottom_row_y;
        width: root.top_card_width;
        height: root.bottom_card_height;
        title: "监控区域";
        subtitle: "后续在这里接视频监控、抓拍画面或识别结果。";
        badge_text: "右侧监控";
    }
}
